generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique @default(uuid())
  name          String
  slug          String   @unique
  description   String?
  costPrice     Decimal  @default(0) @db.Decimal(10, 2)
  sellingPrice  Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  currency      String   @default("GHS")
  category      String?
  brand         String?
  sizes         String[]
  colors        String[]
  tags          String[]
  sku           String?  @unique
  imageUrl      String?
  gallery       String[]
  inStock       Boolean  @default(true)
  stockQty      Int      @default(0)
  isFeatured    Boolean  @default(false)
  isOnSale      Boolean  @default(false)
  isNewArrival  Boolean  @default(false)
  discountPercent Int?
  discountExpiresAt DateTime?
  rating        Decimal  @default(0) @db.Decimal(3, 2)
  reviewsCount  Int      @default(0)
  viewsCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems   OrderItem[]
  productViews ProductView[]
  flashSales   FlashSaleProduct[]

  @@index([slug])
  @@index([category])
  @@index([createdAt(sort: Desc)])
  @@index([isOnSale])
  @@index([isFeatured])
  @@map("afi_products")
}

model Category {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  name        String
  slug        String   @unique
  imageUrl    String?
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([slug])
  @@map("afi_categories")
}

model Customer {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  email       String   @unique
  name        String
  phone       String?
  city        String?
  address     String?
  totalOrders Int      @default(0)
  totalSpent  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]

  @@index([email])
  @@index([createdAt(sort: Desc)])
  @@map("afi_customers")
}

model Coupon {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @default(uuid())
  code              String    @unique
  description       String?
  discountType      String    @default("percentage")
  discountValue     Decimal   @db.Decimal(10, 2)
  minOrderAmount    Decimal?  @db.Decimal(10, 2)
  maxDiscountAmount Decimal?  @db.Decimal(10, 2)
  maxUses           Int?
  usedCount         Int       @default(0)
  expiresAt         DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orders Order[]

  @@index([code])
  @@index([isActive])
  @@map("afi_coupons")
}

model Order {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique @default(uuid())
  customerId     Int?
  customerName   String?
  customerEmail  String?
  customerPhone  String?
  couponId       Int?
  couponCode     String?
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal  @db.Decimal(10, 2)
  currency       String   @default("GHS")
  status         String   @default("pending")
  paymentMethod  String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  coupon   Coupon?   @relation(fields: [couponId], references: [id])
  items    OrderItem[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt(sort: Desc)])
  @@map("afi_orders")
}

model OrderItem {
  id           Int      @id @default(autoincrement())
  orderId      Int
  productId    Int?
  productName  String
  quantity     Int      @default(1)
  costPrice    Decimal  @db.Decimal(10, 2)
  sellingPrice Decimal  @db.Decimal(10, 2)
  subtotal     Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  order   Order    @relation(fields: [orderId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@map("afi_order_items")
}

model ProductView {
  id        Int      @id @default(autoincrement())
  productId Int
  referrer  String   @default("direct")
  viewedAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([viewedAt(sort: Desc)])
  @@map("afi_product_views")
}

model FlashSale {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(uuid())
  title       String
  description String?
  discountPercent Int
  startTime   DateTime
  endTime     DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products FlashSaleProduct[]

  @@index([isActive])
  @@index([startTime])
  @@index([endTime])
  @@map("afi_flash_sales")
}

model FlashSaleProduct {
  id          Int  @id @default(autoincrement())
  flashSaleId Int
  productId   Int

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([flashSaleId, productId])
  @@index([productId])
  @@map("afi_flash_sale_products")
}

model HomepageBanner {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(uuid())
  section     String    @default("new-arrivals")
  title       String?
  description String?
  imageUrl    String?
  linkUrl     String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([section])
  @@index([isActive])
  @@map("afi_homepage_banners")
}

model Announcement {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid())
  message   String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
  @@map("afi_announcements")
}

model NewsletterSubscriber {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(uuid())
  email     String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([isActive])
  @@map("afi_newsletter_subscribers")
}